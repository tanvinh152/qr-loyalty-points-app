meta {
  name: bad-body
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/webhooks/pancake
  body: json
  auth: none
}

headers {
  content-type: application/json
  x-webhook-secret: {{webhookSecret}}
}

body:json {
  {
    "status": 3
  }
}

docs {
  Valid secret but no order identifier anywhere in the payload -> 422. This is
  one of the few non-2xx business responses: without an id there is nothing to
  look up, and a retry would fail identically.
}

assert {
  res.status: eq 422
}
