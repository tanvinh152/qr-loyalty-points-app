meta {
  name: bad-secret
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/webhooks/pancake
  body: json
  auth: none
}

headers {
  content-type: application/json
  x-webhook-secret: deadbeef
}

body:json {
  {
    "id": "{{orderId}}"
  }
}

docs {
  Wrong shared secret -> 401, before the body is even read. A missing header and
  an unset WEBHOOK_SECRET both fail closed the same way.
}

assert {
  res.status: eq 401
}
